# ─────────────────────────────────────────────────
# Notion API 設定
# ─────────────────────────────────────────────────
# 1. https://www.notion.so/my-integrations でインテグレーションを作成
# 2. 「内部インテグレーショントークン」をコピーして下に貼り付ける
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notionのメニューデータベースのページを開き、
# URLの中にある32文字のIDをコピーして貼り付ける
# 例: https://notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx?v=...
#                        ↑ この32文字
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
